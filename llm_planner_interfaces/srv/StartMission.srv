# StartMission.srv
# Sent to the orchestrator to start executing a mission (high-level goal).
# The orchestrator plans, generates BTs step by step, executes them, and replans on failure.
string goal       # High-level goal description
string context    # Optional context: robot role, environment, constraints, current state.
                  # Helps the planner break the goal into relevant steps.
string[] skills   # Capabilities the robot has (e.g. "Navigate to a location",
                  # "Speak using TTS"). Passed verbatim to plan and replan requests.
string mission_name  # Optional short identifier used to prefix saved plan filenames.
---
bool accepted     # False if orchestrator is already busy
string message
