# PlanTask.srv
# Generates a YAML execution plan from a high-level goal using an LLM.
# The plan contains sequential steps, each with a description and bt_prompt
# that will be used to generate a Behavior Tree via llm_bt_builder.
string goal          # High-level goal description
string context       # Optional context: robot role, environment, constraints, current state.
                     # Helps the LLM break the goal into relevant sequential steps.
string[] skills      # Capabilities the robot has (e.g. "Navigate to a location",
                     # "Speak using TTS"). The LLM plans *only* using these skills.
string[] preconditions  # Constraints or conditions before action execution
string[] postconditions # Expected results or invariants post-execution
string mission_name  # Optional short identifier used to prefix saved plan filenames.
                     # If empty, defaults to the generic prefix ("plan" / "agent_plan").
---
bool success
string plan_yaml     # YAML plan content (see plan_template.yaml for format)
string message
